# Plantilla de variables de entorno del backend.
# Copia este archivo como ".env" y ajusta los valores si lo necesitas:
#   Windows (PowerShell):  Copy-Item .env.example .env
#   Linux/Mac:             cp .env.example .env

# Base de datos SQLite (archivo local). Para PostgreSQL cambia el provider
# en prisma/schema.prisma y esta URL.
DATABASE_URL="file:./dev.db"

# Clave para firmar los tokens de sesión (JWT). Cámbiala en producción.
JWT_SECRET="cambia-esta-clave-secreta-en-produccion"

# Puerto de la API
PORT=4000
